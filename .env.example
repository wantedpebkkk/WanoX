# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains sensitive secrets!

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Optional: change the command prefix (default: Wa!)
BOT_PREFIX=Wa!

# Optional: ticket category name (default: Tickets)
TICKET_CATEGORY=Tickets

# Optional: send welcome messages to a specific channel ID
WELCOME_CHANNEL_ID=

# Optional: log moderation actions to a specific channel ID
LOG_CHANNEL_ID=

# Optional: dashboard host/port (default: 0.0.0.0:5000)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
